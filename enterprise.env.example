# Infinite Canvas Enterprise example configuration
#
# Copy this file to enterprise.env for local deployment.
# Do not commit the real enterprise.env file.
#
# Production requirements:
# - Change JWT_SECRET to a long random value, at least 32 characters.
# - Change ADMIN_PASSWORD before exposing the service on a LAN or server.
# - Keep enterprise.env out of Git.

GATEWAY_PORT=8000
UPSTREAM_PORT=3001
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRE_HOURS=168
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-before-production
DB_PATH=data/enterprise.db

# Enterprise project entry and update governance:
ENTERPRISE_REPO_URL=https://github.com/MEIS-DaCaiTou/Infinite-Canvas-Enterprise
ENTERPRISE_UPDATE_ENABLED=true
ENTERPRISE_HIDE_UPSTREAM_AUTHOR=true

# Optional production guard:
# ENTERPRISE_ENV=production
# or:
# ENTERPRISE_STRICT_SECURITY=1
